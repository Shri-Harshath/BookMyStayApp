import java.util.*;

class Reservation {
    String reservationId;
    String customerName;
    String roomType;
    String roomId;
    boolean active;

    Reservation(String reservationId, String customerName, String roomType, String roomId) {
        this.reservationId = reservationId;
        this.customerName = customerName;
        this.roomType = roomType;
        this.roomId = roomId;
        this.active = true;
    }
}

class InventoryService {
    HashMap<String, Integer> inventory = new HashMap<>();

    InventoryService() {
        inventory.put("Single", 1);
        inventory.put("Double", 1);
        inventory.put("Suite", 1);
    }

    void increase(String type) {
        inventory.put(type, inventory.get(type) + 1);
    }

    void showInventory() {
        for (String key : inventory.keySet()) {
            System.out.println(key + " : " + inventory.get(key));
        }
    }
}

class CancellationService {
    HashMap<String, Reservation> reservations;
    Stack<String> rollbackStack = new Stack<>();
    InventoryService inventory;

    CancellationService(HashMap<String, Reservation> reservations, InventoryService inventory) {
        this.reservations = reservations;
        this.inventory = inventory;
    }

    void cancel(String reservationId) {
        if (!reservations.containsKey(reservationId)) {
            System.out.println("Cancellation failed: Reservation not found");
            return;
        }

        Reservation r = reservations.get(reservationId);

        if (!r.active) {
            System.out.println("Cancellation failed: Already cancelled");
            return;
        }

        rollbackStack.push(r.roomId);
        inventory.increase(r.roomType);
        r.active = false;

        System.out.println("Booking cancelled for " + r.customerName +
                " Room Released: " + rollbackStack.pop());
    }
}

public class UseCase10BookingCancellation {
    public static void main(String[] args) {

        InventoryService inventory = new InventoryService();
        HashMap<String, Reservation> reservations = new HashMap<>();

        reservations.put("R101", new Reservation("R101", "Arun", "Single", "S1"));
        reservations.put("R102", new Reservation("R102", "Meena", "Double", "D1"));
        reservations.put("R103", new Reservation("R103", "Rahul", "Suite", "SU1"));

        CancellationService cancelService =
                new CancellationService(reservations, inventory);

        cancelService.cancel("R102");
        cancelService.cancel("R102");
        cancelService.cancel("R200");

        System.out.println();
        System.out.println("Updated Inventory");
        inventory.showInventory();
    }
}